APP_ENV=development
HTTP_PORT=8080
WORKER_METRICS_PORT=9091
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

MONGODB_URI=mongodb://mongodb:27017/?replicaSet=rs0
MONGODB_DATABASE=cinema
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

REDIS_ADDR=redis:6379
REDIS_PASSWORD=cinema-local-redis
REDIS_DB=0
SEAT_LOCK_TTL=5m
HOLD_SWEEP_INTERVAL=5s

RABBITMQ_USER=cinema
RABBITMQ_PASSWORD=cinema-local-rabbit
RABBITMQ_URL=amqp://cinema:cinema-local-rabbit@rabbitmq:5672/
RABBITMQ_EXCHANGE=cinema.events
RABBITMQ_QUEUE=booking.notifications

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/v1/auth/google/callback

ADMIN_EMAILS=admin@example.com
SESSION_COOKIE_NAME=cinema_session
SESSION_TTL=12h
OAUTH_STATE_TTL=10m
COOKIE_SECURE=false
HOLD_RATE_LIMIT=10
LOG_LEVEL=info

OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_ENABLED=true
