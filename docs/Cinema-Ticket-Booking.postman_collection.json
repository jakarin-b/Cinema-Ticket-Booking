                  "const body = pm.response.json();",
                  "const seat = body.data?.find((item) => item.seat_id === pm.collectionVariables.get('seat_id'));",
                  "pm.test('Confirmed seat is BOOKED', () => pm.expect(seat?.status).to.eql('BOOKED'));",
                  "pm.test('Seat references the booking', () => pm.expect(seat?.booking_id).to.eql(pm.collectionVariables.get('booking_id')));"
                ]
