    },
    {
      "name": "04 - Booking Confirmation Flow",
      "description": "End-to-end authenticated flow. It creates a hold, proves both idempotent operations, confirms the mock payment, and verifies the resulting booked seat.",
      "item": [
        {
          "name": "Create hold",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('hold_idempotency_key', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Active hold is returned', () => pm.expect(body.data.status).to.eql('ACTIVE'));",
                  "pm.test('Hold contains the requested seat', () => pm.expect(body.data.seat_ids).to.include(pm.collectionVariables.get('seat_id')));",
                  "if (body.data?.hold_id) {",
                  "  pm.collectionVariables.set('hold_id', body.data.hold_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{hold_idempotency_key}}",
                "type": "text"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrf_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seat_ids\": [\n    \"{{seat_id}}\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{api_url}}/showtimes/{{showtime_id}}/holds",
            "description": "Atomically holds one to ten seats for five minutes. The pre-request script creates one idempotency key and the test saves `hold_id`."
          }
        },
        {
          "name": "Retry create hold with same idempotency key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Existing hold returns 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('The same hold is returned', () => pm.expect(body.data.hold_id).to.eql(pm.collectionVariables.get('hold_id')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{hold_idempotency_key}}",
                "type": "text"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrf_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seat_ids\": [\n    \"{{seat_id}}\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{api_url}}/showtimes/{{showtime_id}}/holds",
            "description": "Repeats the exact hold request with the same key and expects the original hold instead of a duplicate."
          }
        },
        {
          "name": "Get hold",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Owned hold is active', () => {",
                  "  pm.expect(body.data.hold_id).to.eql(pm.collectionVariables.get('hold_id'));",
                  "  pm.expect(body.data.status).to.eql('ACTIVE');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{api_url}}/holds/{{hold_id}}",
            "description": "Returns a hold owned by the current user, including server-side remaining seconds."
          }
        },
        {
          "name": "Confirm hold",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('confirm_idempotency_key', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Confirmed booking is returned', () => {",
                  "  pm.expect(body.data.booking_status).to.eql('CONFIRMED');",
                  "  pm.expect(body.data.payment_status).to.eql('PAID');",
                  "});",
                  "if (body.data?.id) {",
                  "  pm.collectionVariables.set('booking_id', body.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{confirm_idempotency_key}}",
                "type": "text"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrf_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"MOCK\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{api_url}}/holds/{{hold_id}}/confirm",
            "description": "Confirms an unexpired hold using the only supported payment method, `MOCK`, and saves `booking_id`."
          }
        },
        {
          "name": "Retry confirm with same idempotency key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Existing booking returns 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('The same booking is returned', () => pm.expect(body.data.id).to.eql(pm.collectionVariables.get('booking_id')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{confirm_idempotency_key}}",
                "type": "text"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrf_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"MOCK\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{api_url}}/holds/{{hold_id}}/confirm",
            "description": "Repeats confirmation with the same key and expects the original booking."
          }
        },
        {
          "name": "List my bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Bookings are paginated', () => {",
                  "  pm.expect(body.data).to.be.an('array');",
                  "  pm.expect(body.meta.page).to.eql(1);",
                  "  pm.expect(body.meta.limit).to.eql(20);",
                  "});",
                  "pm.test('New booking is listed', () => pm.expect(body.data.some((booking) => booking.id === pm.collectionVariables.get('booking_id'))).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
