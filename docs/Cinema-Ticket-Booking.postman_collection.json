  "item": [
    {
      "name": "01 - Health",
      "description": "Public health endpoints for the API and background worker.",
      "item": [
        {
          "name": "API liveness",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('API reports live', () => pm.expect(body.data.status).to.eql('live'));",
                  "pm.test('Response has a request ID', () => pm.expect(body.meta.request_id).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/health/live",
            "description": "Checks whether the API process is running."
          }
        },
        {
          "name": "API readiness",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is ready or reports an unconfigured dependency', () => pm.expect([200, 503]).to.include(pm.response.code));",
                  "const body = pm.response.json();",
                  "pm.test('Response includes dependency information', () => pm.expect(body.data?.checks || body.error?.details).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/health/ready",
            "description": "Returns 200 when MongoDB, Redis, RabbitMQ, Firebase, and Google OAuth are ready. A local stack without both auth providers intentionally returns 503 with dependency details."
          }
        },
        {
          "name": "Worker liveness",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Worker reports live', () => pm.expect(pm.response.json().status).to.eql('live'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
