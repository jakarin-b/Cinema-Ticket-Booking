    {
      "name": "05 - Manual Release Flow",
      "description": "A separate end-to-end path that selects another available seat, creates a different hold, and releases it without affecting the confirmed-booking flow.",
      "item": [
        {
          "name": "Select another available seat",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const available = body.data?.find((seat) => seat.status === 'AVAILABLE' && seat.seat_id !== pm.collectionVariables.get('seat_id'));",
                  "pm.test('Another seat is available', () => pm.expect(available, 'release-flow seat').to.exist);",
                  "if (available) {",
                  "  pm.collectionVariables.set('release_seat_id', available.seat_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{api_url}}/showtimes/{{showtime_id}}/seats",
            "description": "Finds another available seat and saves it as `release_seat_id`."
          }
        },
        {
          "name": "Create hold to release",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('release_idempotency_key', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Active hold is returned', () => pm.expect(body.data.status).to.eql('ACTIVE'));",
                  "if (body.data?.hold_id) {",
                  "  pm.collectionVariables.set('release_hold_id', body.data.hold_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{release_idempotency_key}}",
                "type": "text"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrf_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seat_ids\": [\n    \"{{release_seat_id}}\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{api_url}}/showtimes/{{showtime_id}}/holds",
            "description": "Creates an independent active hold and saves it as `release_hold_id`."
          }
        },
        {
          "name": "Release hold",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Hold is released', () => {",
                  "  pm.expect(body.data.hold_id).to.eql(pm.collectionVariables.get('release_hold_id'));",
                  "  pm.expect(body.data.status).to.eql('RELEASED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrf_token}}",
                "type": "text"
              }
            ],
            "url": "{{api_url}}/holds/{{release_hold_id}}",
            "description": "Idempotently releases an active hold owned by the current user."
          }
        },
        {
          "name": "Get released hold",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Released status is persisted', () => pm.expect(body.data.status).to.eql('RELEASED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{api_url}}/holds/{{release_hold_id}}",
            "description": "Reads the released hold to verify its terminal status."
          }
        }
      ]
    },
