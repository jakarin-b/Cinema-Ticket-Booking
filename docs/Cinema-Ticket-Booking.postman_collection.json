    {
      "name": "02 - Authentication",
      "description": "Use a Firebase ID token for normal API testing. Direct Google OAuth is included as a browser-oriented alternative.",
      "item": [
        {
          "name": "Create Firebase session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Firebase identity is resolved', () => pm.expect(body.data.auth_method).to.eql('firebase'));",
                  "if (body.data?.user) {",
                  "  pm.collectionVariables.set('current_user_email', body.data.user.email);",
                  "  pm.collectionVariables.set('current_user_role', body.data.user.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{api_url}}/auth/session",
            "description": "Verifies `firebase_token`, upserts the local user, links the provider identity, and resolves the server-side role. The endpoint does not return a new token; protected requests reuse the Firebase token."
          }
        },
        {
          "name": "Current user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Authenticated user is returned', () => pm.expect(body.data.user.email).to.be.a('string').and.not.empty);",
                  "if (body.data.csrf_token) {",
                  "  pm.collectionVariables.set('csrf_token', body.data.csrf_token);",
                  "}",
                  "pm.collectionVariables.set('current_user_email', body.data.user.email);",
                  "pm.collectionVariables.set('current_user_role', body.data.user.role);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{api_url}}/auth/me",
            "description": "Returns the current principal. When authenticated by the `cinema_session` cookie, the test script saves the returned CSRF token for mutating requests."
          }
        },
        {
          "name": "Start direct Google OAuth",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OAuth starts or reports missing provider configuration', () => pm.expect([302, 503]).to.include(pm.response.code));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{api_url}}/auth/google/start?return_to=/",
            "description": "Starts the direct Google authorization-code flow. Redirect following is disabled so the response can be inspected. Complete the interactive provider login in a browser; Postman's HTTP runner cannot complete it automatically."
          },
          "protocolProfileBehavior": {
            "followRedirects": false
          }
        },
        {
          "name": "Google OAuth callback (provider-controlled)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Callback redirects to the frontend', () => pm.response.to.have.status(302));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{api_url}}/auth/google/callback?state={{oauth_state}}&code={{oauth_code}}",
            "description": "Provider-controlled callback included for route completeness. Google normally supplies `state` and `code`; calling it manually with empty or stale values redirects to the frontend error page and clears the one-time OAuth state cookie."
          },
          "protocolProfileBehavior": {
            "followRedirects": false
          }
        }
      ]
    },
    {
      "name": "03 - Catalogue",
      "description": "Public read-only catalogue. Run this folder before either hold flow so IDs are selected from current seed data.",
      "item": [
        {
          "name": "List movies",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('At least one active movie is returned', () => pm.expect(body.data).to.be.an('array').that.is.not.empty);",
                  "if (body.data?.length) {",
                  "  pm.collectionVariables.set('movie_id', body.data[0].id);",
                  "}"
