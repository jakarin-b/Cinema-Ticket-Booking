          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const available = body.data?.find((seat) => seat.status === 'AVAILABLE');",
                  "pm.test('At least one seat is available', () => pm.expect(available, 'available seat').to.exist);",
